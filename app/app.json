{
  "expo": {
    "name": "VoiceAPI",
    "slug": "voiceapi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "plugins": [
      "./plugins/withForegroundService",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png"
        }
      ],
      "expo-asset"
    ],
    "android": {
      "package": "com.voiceapi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.voiceapi.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VoiceAPI needs microphone access to record audio for transcription.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "extra": {
      "apiBaseUrl": "http://192.168.1.146:8000"
    }
  }
}
